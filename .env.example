# ── Copy this file to .env and fill in your values ──────────────
# cp .env.example .env

# ── Inference ────────────────────────────────────────────────────
INFERENCE_BACKEND=pytorch          # pytorch | onnx | tensorrt
MODEL_PATH=weights/yolov8s-seg.pt
DETECTION_CONF=0.35
DETECTION_IOU=0.45
MODEL_INPUT_SIZE=640
INFERENCE_DEVICE=cuda              # cuda | cpu

# ── Tracking ─────────────────────────────────────────────────────
TRACKER=botsort                    # botsort | bytetrack
TRACK_THRESH=0.35
MATCH_THRESH=0.45
TRACK_BUFFER=30

# ── Motion ───────────────────────────────────────────────────────
MOTION_THRESH=0.016
PIXEL_DIFF_THRESH=20
ACTIVE_CONFIRM_FRAMES=4
TEMPORAL_WINDOW=5
LLM_CONF_THRESH=0.65
TRUCK_STILL_CONFIRM=5        # extra still frames before truck flips INACTIVE
TRUCK_LOADING_DIST=150       # pixel distance: truck ↔ dumping arm

# ── Video ────────────────────────────────────────────────────────
VIDEO_SOURCE=data/input.mp4
PROCESS_FPS=10
OUTPUT_DIR=data/output

# ── Kafka ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_DETECTIONS=equipment.detections
KAFKA_TOPIC_FRAMES=equipment.frames
KAFKA_CONSUMER_GROUP=analytics-group

# ── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=construction_cv
DB_USER=cvuser
DB_PASSWORD=cvpassword

# ── LLM ──────────────────────────────────────────────────────────
LLM_ENABLED=true
LLM_PROVIDER=openai                # openai | gemini | groq | ollama
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=                      # required for groq / ollama
LLM_TEMP=0.1
LLM_MAX_TOKENS=1024

# ── API ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
